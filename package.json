{
  "name": "bruno-mcp-server",
  "version": "0.1.0",
  "description": "Local-first MCP server for discovering, inspecting, and running Bruno API requests",
  "type": "module",
  "bin": {
    "bruno-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@usebruno/cli": "^1.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "eslint": "^9.5.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
